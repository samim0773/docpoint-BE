# ─── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/docpoint?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=your_super_secret_access_key_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── Admin JWT (separate secret) ──────────────────────────────
JWT_ADMIN_SECRET=your_super_secret_admin_key_min_32_chars
JWT_ADMIN_EXPIRES=8h

# ─── Doctor JWT ────────────────────────────────────────────────
JWT_DOCTOR_SECRET=your_super_secret_doctor_key_min_32_chars

# ─── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Razorpay ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── MSG91 (SMS) ───────────────────────────────────────────────
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=DOCPNT
MSG91_OTP_TEMPLATE_ID=your_otp_template_id
MSG91_BOOKING_TEMPLATE_ID=your_booking_template_id
MSG91_QUEUE_TEMPLATE_ID=your_queue_alert_template_id

# ─── Cloudinary ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Google Maps ───────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ─── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:4200,http://localhost:3000

# ─── Admin Seed ────────────────────────────────────────────────
ADMIN_EMAIL=admin@docpoint.in
ADMIN_PASSWORD=Admin@DocPoint#2025
